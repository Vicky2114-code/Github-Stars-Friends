# repo-dive env vars
# Copy to .env.local and fill in for local dev. Set the same in Vercel project settings.

# GitHub Personal Access Token. Used by lib/github.ts.
# Scopes: public_repo (no write). 5000 req/hr bucket.
# Generate at: https://github.com/settings/tokens
GITHUB_PAT=

# Google AI Studio API key for Gemini Flash.
# Used by lib/ai-discoverability.ts for the 3-prompt discoverability matrix.
# Generate at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Vercel KV. Auto-injected when you link a KV store in the Vercel dashboard.
# For local dev: pull via `vercel env pull .env.local`.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
